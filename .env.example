# ML Experiment Tracking Platform - Environment Variables
# Copy this file to .env and adjust values as needed.

# --- Storage ---
MLTRACK_DB_PATH=./tracking.db
MLTRACK_ARTIFACT_ROOT=./artifacts

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# --- PostgreSQL (optional, for production) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=mltrack
POSTGRES_PASSWORD=changeme
POSTGRES_DATABASE=ml_experiments

# --- Redis (optional, for caching) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=false
